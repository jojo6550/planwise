# PlanWise Application Configuration

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=planwise_db
DB_USER=root
DB_PASS=

# Mail Configuration
MAIL_DRIVER=mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=PlanWise
MAIL_FROM_EMAIL=noreply@planwise.local

# Application Environment
APP_ENV=production
APP_DEBUG=false
APP_NAME=PlanWise
APP_URL=http://localhost/planwise/public/

# Session Configuration
SESSION_TIMEOUT=1800

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/uploads/

# QR Code Configuration
QR_CODE_DIR=/public/qr/
